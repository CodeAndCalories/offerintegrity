# ============================================================
# OfferIntegrity.io — Environment Variables
# ============================================================

# ---- Web App (apps/web) ----
# Set in Cloudflare Pages dashboard or .env.local for dev

# Your deployed Worker URL
NEXT_PUBLIC_WORKER_URL=http://localhost:8787

# Cloudflare Turnstile site key (public)
# Get from: https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ---- Worker (apps/worker) ----
# Set via `wrangler secret put <KEY>` or in wrangler.toml [vars]

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (email)
RESEND_API_KEY=re_...

# Cloudflare Turnstile (secret key)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# OpenAI (only needed if USE_REAL_AI=true)
OPENAI_API_KEY=sk-...

# Feature flags
USE_REAL_AI=false

# URLs
WORKER_URL=https://worker.offerintegrity.io
APP_URL=https://offerintegrity.io
