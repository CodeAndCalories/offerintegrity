# OfferIntegrity — Environment Variables Reference
# Updated to include new additions from this release

# ════════════════════════════════════════════════════
# apps/web — Cloudflare Pages environment variables
# ════════════════════════════════════════════════════

# Required
NEXT_PUBLIC_WORKER_URL=https://api.offerintegrity.io
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Optional — Cloudflare Web Analytics
# Get your token from: dash.cloudflare.com → Analytics → Web Analytics → Add site
# Leave unset to disable analytics entirely (no snippet injected)
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# ════════════════════════════════════════════════════
# apps/worker — Cloudflare Worker secrets & vars
# ════════════════════════════════════════════════════

# Existing (no change)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
RESEND_API_KEY=re_...
TURNSTILE_SECRET_KEY=...
OPENAI_API_KEY=sk-...         # only if USE_REAL_AI=true
WORKER_URL=https://api.offerintegrity.io
APP_URL=https://offerintegrity.io

# In wrangler.toml [vars] (not secret)
# USE_REAL_AI = "true"

# ── NEW in this release ──────────────────────────────
# Secret token required to call POST /api/resend
# Generate a strong random string, e.g.: openssl rand -hex 32
# Set via: wrangler secret put RESEND_SUPPORT_TOKEN
RESEND_SUPPORT_TOKEN=your_secret_support_token_here

# ════════════════════════════════════════════════════
# Cloudflare Settings Checklist
# ════════════════════════════════════════════════════
#
# Worker:
#   1. wrangler secret put RESEND_SUPPORT_TOKEN
#   2. Confirm KV binding OFFER_KV is still attached
#   3. Deploy: cd apps/worker && npm run deploy
#
# Pages:
#   1. Add NEXT_PUBLIC_CF_ANALYTICS_TOKEN (optional — leave blank to skip)
#   2. Re-deploy to pick up new layout.tsx changes
#
# No new KV namespaces, D1 databases, or other bindings needed.
